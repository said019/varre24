# ============================================================
# VARRE24 — Variables de Entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.
# ============================================================

# ─── CORE (requerido) ──────────────────────────────────────

# Backend API para el frontend en build (en dev se usa el proxy de Vite → /api)
VITE_API_URL=https://<tu-backend>.up.railway.app/api

# URL pública de la app (usada en links de emails: reset password, etc.)
APP_URL=https://varre24fit.com

# URL base de assets públicos/email branding (si no se define, usa APP_URL)
SITE_URL=https://varre24fit.com

# Orígenes permitidos por CORS (separados por coma)
CORS_ALLOWED_ORIGINS=https://varre24fit.com,http://localhost:5173,http://127.0.0.1:5173

# Base de datos PostgreSQL (Railway / local). En BD virgen el backend aplica
# schema_complete.sql automáticamente al arrancar.
DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway

# Secreto JWT para firmar tokens (genera uno largo y aleatorio)
# p. ej.:  openssl rand -base64 64
JWT_SECRET=<genera-uno-largo-y-aleatorio>

# Puerto del backend (Railway lo inyecta automáticamente en prod)
PORT=8080

# ─── ADMIN INICIAL (se siembra al arrancar) ────────────────
# Si ADMIN_PASSWORD se deja vacío, el backend genera una contraseña temporal
# y la imprime UNA vez en los logs del deploy. Cámbiala al primer login.
ADMIN_EMAIL=admin@varre24.com
ADMIN_NAME=Admin VARRE24
ADMIN_PASSWORD=

# ─── PAGOS CON TARJETA — MercadoPago (Checkout Pro) ────────
# Panel: https://www.mercadopago.com.mx/developers/panel/app
# Producción: el Access Token empieza con APP_USR-...  ·  Sandbox: TEST-...
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx
# Public Key — segura para exponer (se sirve por /api/public/mp-config).
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Clave secreta del webhook (panel MP → Webhooks). Vacío = se omite la verificación de firma.
MP_WEBHOOK_SECRET=
# URL pública del backend (para construir notification_url). Si no se define usa APP_URL.
BACKEND_URL=https://varre24fit.com
# URL pública del frontend (para construir back_urls). Si no se define usa APP_URL.
FRONTEND_URL=https://varre24fit.com
# Opcionales (tienen defaults):
MP_CURRENCY=MXN
MP_STATEMENT_DESCRIPTOR=VARRE24
MP_MAX_INSTALLMENTS=12
# Comisión (%) que el cliente absorbe al pagar con tarjeta en línea.
CARD_FEE_PCT=4
# IMPORTANTE: en el panel de MercadoPago configurar el webhook con la URL
#   https://<BACKEND_URL>/webhooks/mercadopago   (evento "Pagos")

# ─── EMAIL TRANSACCIONAL (Resend) ──────────────────────────

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=VARRE24 <notificaciones@varre24fit.com>

# ─── RATE LIMITING (opcional) ──────────────────────────────

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# ─── WHATSAPP (Evolution API, opcional) ────────────────────
# Requiere una instancia propia de Evolution API + un número de WhatsApp
# dedicado, vinculado por QR desde el panel admin.

EVOLUTION_API_URL=https://<tu-instancia>.evolution-api.com
EVOLUTION_API_KEY=<api-key-de-evolution>
EVOLUTION_INSTANCE_NAME=varre24
EVOLUTION_SEND_DELAY_MS=1200

# ─── GOOGLE WALLET (opcional, membership passes) ───────────

GOOGLE_ISSUER_ID=<tu-google-pay-issuer-id>
GOOGLE_ISSUER_NAME=VARRE24
GOOGLE_PROGRAM_NAME=VARRE24 Club
GOOGLE_HEX_BACKGROUND_COLOR=#FAF3EA
GOOGLE_HEX_BACKGROUND_COLOR_EVENT=#752223
GOOGLE_WALLET_SHOW_FULL_TEXT=true
GOOGLE_SA_EMAIL=<service-account>@<project>.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternativa base64 del JSON completo de la service account
GOOGLE_SA_KEY_JSON_BASE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# ─── APPLE WALLET (opcional, membership passes) ────────────

APPLE_PASS_TYPE_ID=pass.com.varre24.club
APPLE_TEAM_ID=<tu-apple-team-id>
APPLE_KEY_ID=<tu-apple-key-id>
APPLE_CERT_PASSWORD=<password-del-cert-si-aplica>
APPLE_AUTH_TOKEN=<token-para-apns>
APPLE_APNS_HOST=api.push.apple.com
# Los certs/llaves se suben como base64 en prod (Railway) o paths locales en dev
APPLE_PASS_CERT_BASE=
APPLE_PASS_KEY_BASE=
APPLE_PASS_WWDR_BASE=
APPLE_APNS_KEY_BASE=
APPLE_WALLET_SHOW_FRONT_TEXT_MEMBERSHIP=true
APPLE_WALLET_SHOW_FRONT_TEXT_EVENT=true

# ─── AUTO CHECK-IN ─────────────────────────────────────────
# Cron interno que cada 10 min marca 'checked_in' las reservas confirmadas
# cuya clase ya terminó (start + duración ≤ ahora, TZ MX). Idempotente.
AUTO_CHECKIN_ENABLED=true

# ─── COBRO POR TRANSFERENCIA ───────────────────────────────
# Activación automática de membresía al subir comprobante. Si pasan 24h sin
# que el admin revise y la alumna no tomó clases, se revierte sola.
AUTO_REVERT_ENABLED=true

# Correos que reciben la notificación "Nueva orden por verificar" (CSV).
# Se combinan con cualquier usuario con rol admin/super_admin.
ADMIN_NOTIFY_EMAILS=
